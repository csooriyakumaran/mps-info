#include <winver.h>

IDI_APP_ICON ICON "@CMAKE_CURRENT_SOURCE_DIR@/resources/aiolos.ico"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "Aiolos Engineering Corporation\0"
            VALUE "FileDescription", "mps-info utility\0"
            VALUE "FileVersion", "@PROJECT_VERSION@.0\0"
            VALUE "InternalName", "mps-info\0"
            VALUE "OriginalFilename", "mps-info.exe\0"
            VALUE "ProductName", "mps-info\0"
            VALUE "ProductVersion", "@PROJECT_VERSION@.0\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
